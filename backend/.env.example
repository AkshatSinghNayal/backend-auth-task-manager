# Backend environment variables
PORT=5000
MONGO_URI=mongodb://localhost:27017/task-manager
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d
# Optional: users who register with matching admin code become admin
ADMIN_INVITE_CODE=
# Comma-separated list of allowed frontend origins (use * to allow all)
CORS_ORIGIN=http://localhost:3000
